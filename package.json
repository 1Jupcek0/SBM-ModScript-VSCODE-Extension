{
	"name": "modscriptintellisense",
	"displayName": "Modscript IntelliSense",
	"version": "0.2.4",
	"publisher": "jaysonmaw",
	"engines": {
		"vscode": "^1.32.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "modscript",
				"aliases": [
					"Modscript",
					"modscript"
				],
				"extensions": [
					".tscm"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "modscript",
				"scopeName": "source.tscm",
				"path": "./syntaxes/modscript.tmLanguage.json"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "composer-explorer",
					"title": "Composer Explorer",
					"icon": "media/Composer.svg"
				}
			]
		},
		"views": {
			"composer-explorer": [
				{
					"id": "composerExplorer",
					"name": "Composer Explorer",
					"icon": "media/Composer.svg",
					"visibility": "visible"
				},
				{
					"id": "modscriptCheckedOut",
					"name": "Checked Out",
					"icon": "media/Composer.svg"
				},
				{
					"id": "modscriptFavourites",
					"name": "Favourites",
					"icon": "media/Composer.svg"
				},
				{
					"id": "modscriptKnowledgeBase",
					"name": "Code Snippets",
					"icon": "media/Composer.svg"
				},
				{
					"id": "modscriptOutline",
					"name": "Modscript Outline",
					"icon": "media/Composer2.svg"
				}
			]
		},
		"commands": [
			{
				"command": "extension.searchComposerFiles",
				"title": "Search Composer Files",
				"icon": "$(search)"
			},
			{
				"command": "extension.searchComposerFilesFuzzy",
				"title": "Search Composer Files For Partial/Fuzzy Match",
				"icon": "$(search-fuzzy)"
			},
			{
				"command": "extension.composerSearchStop",
				"title": "Show All Files (remove search filter)",
				"icon": "$(search-stop)"
			},
			{
				"command": "extension.composerRefreshRepository",
				"title": "Refresh repository from cache by restarting Extension Host",
				"icon": "$(extensions-refresh)"
			},
			{
				"command": "extension.composerOpenSettings",
				"title": "Refresh repository from cache by restarting Extension Host",
				"icon": "$(settings-gear)"
			},
			{
				"command": "extension.composerExpandAll",
				"title": "Expand all solutions in the tree view",
				"icon": "$(expand-all)"
			},
			{
				"command": "extension.composerCollapseAll",
				"title": "Collapse all solutions in the tree view",
				"icon": "$(collapse-all)"
			},
			{
				"command": "extension.openSettingsPanel",
				"title": "Modscript: Open settings panel",
				"icon": "$(settings)"
			},
			{
				"command": "extension.openWelcome",
				"title": "Modscript: Open Welcome"
			},
			{
				"command": "extension.addFavourite",
				"title": "Add to Favourites",
				"icon": "$(star-empty)"
			},
			{
				"command": "extension.removeFavourite",
				"title": "Remove from Favourites",
				"icon": "$(star-delete)"
			},
			{
				"command": "extension.kbAdd",
				"title": "Code Snippets: Add Snippet",
				"icon": "$(add)"
			},
			{
				"command": "extension.kbAddFromSelection",
				"title": "Modscript: Save Selection to Code Snippets"
			},
			{
				"command": "extension.kbDelete",
				"title": "Delete Snippet",
				"icon": "$(trash)"
			},
			{
				"command": "extension.kbInsert",
				"title": "Insert Snippet"
			},
			{
				"command": "extension.openComposerExplorer",
				"title": "Open Composer Explorer"
			},
			{
				"command": "extension.openClassBrowser",
				"title": "Modscript: Open Reference Browser",
				"icon": "$(library)"
			},
			{
				"command": "extension.outlineGoTo",
				"title": "Modscript: Go to symbol"
			},
			{
				"command": "extension.outlineFuncHide",
				"title": "Hide functions",
				"icon": "$(symbol-function)"
			},
			{
				"command": "extension.outlineFuncShow",
				"title": "Show functions",
				"icon": "$(eye-closed)"
			},
			{
				"command": "extension.outlineClassHide",
				"title": "Hide classes",
				"icon": "$(symbol-class)"
			},
			{
				"command": "extension.outlineClassShow",
				"title": "Show classes",
				"icon": "$(eye-closed)"
			},
			{
				"command": "extension.outlineMethodHide",
				"title": "Hide methods",
				"icon": "$(symbol-method)"
			},
			{
				"command": "extension.outlineMethodShow",
				"title": "Show methods",
				"icon": "$(eye-closed)"
			},
			{
				"command": "extension.outlineGlobalHide",
				"title": "Hide global variables",
				"icon": "$(symbol-variable)"
			},
			{
				"command": "extension.outlineGlobalShow",
				"title": "Show global variables",
				"icon": "$(eye-closed)"
			},
			{
				"command": "extension.outlineInstanceHide",
				"title": "Hide class instances",
				"icon": "$(symbol-object)"
			},
			{
				"command": "extension.outlineInstanceShow",
				"title": "Show class instances",
				"icon": "$(eye-closed)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "extension.searchComposerFiles",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.searchComposerFilesFuzzy",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.composerSearchStop",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.composerRefreshRepository",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.composerOpenSettings",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.composerExpandAll",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.composerCollapseAll",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.openSettingsPanel",
					"when": "view == composerExplorer",
					"group": "navigation"
				},
				{
					"command": "extension.outlineFuncHide",
					"when": "view == modscriptOutline && modscript.outlineShowFunctions",
					"group": "navigation@1"
				},
				{
					"command": "extension.outlineFuncShow",
					"when": "view == modscriptOutline && !modscript.outlineShowFunctions",
					"group": "navigation@1"
				},
				{
					"command": "extension.outlineClassHide",
					"when": "view == modscriptOutline && modscript.outlineShowClasses",
					"group": "navigation@2"
				},
				{
					"command": "extension.outlineClassShow",
					"when": "view == modscriptOutline && !modscript.outlineShowClasses",
					"group": "navigation@2"
				},
				{
					"command": "extension.outlineMethodHide",
					"when": "view == modscriptOutline && modscript.outlineShowMethods",
					"group": "navigation@3"
				},
				{
					"command": "extension.outlineMethodShow",
					"when": "view == modscriptOutline && !modscript.outlineShowMethods",
					"group": "navigation@3"
				},
				{
					"command": "extension.outlineGlobalHide",
					"when": "view == modscriptOutline && modscript.outlineShowGlobals",
					"group": "navigation@4"
				},
				{
					"command": "extension.outlineGlobalShow",
					"when": "view == modscriptOutline && !modscript.outlineShowGlobals",
					"group": "navigation@4"
				},
				{
					"command": "extension.outlineInstanceHide",
					"when": "view == modscriptOutline && modscript.outlineShowInstances",
					"group": "navigation@5"
				},
				{
					"command": "extension.outlineInstanceShow",
					"when": "view == modscriptOutline && !modscript.outlineShowInstances",
					"group": "navigation@5"
				},
				{
					"command": "extension.openClassBrowser",
					"when": "view == modscriptOutline",
					"group": "navigation@6"
				},
				{
					"command": "extension.kbAdd",
					"when": "view == modscriptKnowledgeBase",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "extension.addFavourite",
					"when": "view == composerExplorer && viewItem == composerScript",
					"group": "inline"
				},
				{
					"command": "extension.addFavourite",
					"when": "view == modscriptCheckedOut && viewItem == checkedOutScript",
					"group": "inline"
				},
				{
					"command": "extension.removeFavourite",
					"when": "view == modscriptFavourites && viewItem == favouriteScript",
					"group": "inline"
				},
				{
					"command": "extension.kbDelete",
					"when": "view == modscriptKnowledgeBase && viewItem == kbEntry",
					"group": "inline"
				}
			],
			"editor/context": [
				{
					"command": "extension.kbAddFromSelection",
					"when": "editorLangId == modscript && editorHasSelection",
					"group": "modscript"
				}
			]
		},
		"configuration": {
			"title": "Modscript Settings",
			"properties": {
				"modscript.exportFolder": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "Specifies the folder path you want to save exported composer scripts while using the Composer Explorer. No value defaults to the Documents/SBM Composer/Imports/."
				},
				"modscript.repositoryFolder": {
					"type": [
						"string",
						"null"
					],
					"default": "1",
					"description": "Local Cache Path > Project: Specifies the folder path of the repository, that will be used and shown in Composer Explorer. These folders are named with a number and are located in Local Cache Path (You can find it in SBM Composer Options > Connection > Local Cache Path), from there, select any folder. \nExample: Local Cache Path is C:\\Users\\<username>\\AppData\\Local\\Serena\\Studio\\Repository\\Local, there are folders: ...\\Local\\0, ...\\Local\\1 and ...\\Local\\2, find out which project you need to open and write corresponding number: \"1\"."
				},
				"modscript.checkUndefinedVariables": {
					"type": "boolean",
					"default": true,
					"description": "Warn when a variable reference is not defined anywhere in the current script or its includes. Turn off if it reports too many false positives."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile && npm run -S esbuild-base -- --minify",
		"compile": "tsc ./compileClasses.ts && node ./compileClasses.js && del compileClasses.js && tsc -p ./",
		"lint": "eslint . --ext .ts,.tsx",
		"watch": "tsc ./compileClasses.ts && node ./compileClasses.js && del compileClasses.js && tsc -watch -p ./",
		"esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
		"esbuild": "npm run -S esbuild-base -- --sourcemap",
		"esbuild-watch": "npm run -S esbuild-base -- --sourcemap --watch",
		"package": "vsce package --out packages"
	},
	"devDependencies": {
		"@types/node": "^12.12.0",
		"@types/vscode": "^1.32.0",
		"@typescript-eslint/eslint-plugin": "^4.16.0",
		"@typescript-eslint/parser": "^4.16.0",
		"esbuild": "^0.12.8",
		"eslint": "^7.21.0",
		"typescript": "^4.2.2"
	},
	"dependencies": {
		"xml-js": "^1.6.11"
	},
